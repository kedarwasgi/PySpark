April Admin Employees
'''
Find the number of employees working in the Admin department that joined in April or later, in any year.
'''
>>> Solution:

# Import your libraries
import pyspark
from pyspark.sql.functions import *

# Start writing code
worker = worker.filter((col("department")=='Admin') & (month(col('joining_date'))>=4)).agg(count('*').alias('n_admins'))

# To validate your solution, convert your final pySpark df to a pandas df
worker.toPandas()
